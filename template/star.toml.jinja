# Star manifest — the conformance target every gate reads.
# Canonical schema: the `constellation` StarManifest (pydantic). Generated by
# copier from your answers; this is a substrate star (its runtime is declared as
# kreuzwerker/docker resources in main.tf, deployed via Nereus).
name    = "{{ service_name }}"
service = "{{ project_name }}"
cluster = "{{ cluster }}"
charter = "{{ charter }}"

[substrate]
kind      = "{{ substrate_kind or 'container' }}"
namespace = "{{ star_namespace }}"

[logic]
# Substrate stars have no application entrypoint; the IaC module is the entry.
entrypoint = "main.tf"

[interface]
# Reachability invariant: len(sync) + len(async) >= 1.
sync  = ["{{ interface_protocol }}"]
async = [{% if interstellar %}"kafka"{% endif %}]

# Governance pin — the cosign-signed policy bundle this star subscribes to (F7).
# Renovate bumps `tag` + `digest` when a new bundle publishes (see renovate.json).
[governance]
bundle = "oci://forgejo.notusmi.com/furnace/policy"
tag    = "policy-v1"
digest = "sha256:9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08"
