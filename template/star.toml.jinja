# Star manifest — the conformance target every gate reads.
# Schema authority: stellar_core (build_admission_input) + the ouranos rego policy. Generated by
# copier from your answers; this is a substrate star (its runtime is declared as
# kreuzwerker/docker resources in main.tf, deployed via Nereus).
name    = "{{ service_name }}"
service = "{{ project_name }}"
cluster = "{{ cluster }}"
charter = "{{ charter }}"

[substrate]
kind      = "{{ substrate_kind or 'container' }}"
namespace = "{{ star_namespace }}"

[logic]
# Substrate stars have no application entrypoint; the IaC module is the entry.
entrypoint = "main.tf"

[interface]
# Reachability invariant: len(sync) + len(async) >= 1.
sync  = ["{{ interface_protocol }}"]
async = [{% if interstellar %}"kafka"{% endif %}]

[observability]
# Telemetry surfaces this star exports so Nyx can read its standing. Required by
# the StarManifest schema; exports must be non-empty. The op-contract minimum is
# metrics (the /metrics z-page every star exposes). Extend as the star wires logs/traces.
exports = ["metrics"]

# Governance pin — the cosign-signed policy bundle this star subscribes to (F7).
# Renovate bumps `tag` + `digest` when a new bundle publishes. Config is fleet-
# inherited, not a per-repo renovate.json (this repo has none) — confirmed
# active via its own renovate/* branches (docker-4.x, pin-dependencies, …).
[governance]
bundle = "oci://forgejo.notusmi.com/furnace/policy"
tag    = "policy-v2"
digest = "sha256:3bbda32ae49601b974d87f80e682e56cac442f77f8f5e6ae46bb3bb57ead2a2f"

# [operable] — the star's declared controllable surface (Argus). Opt-in: uncomment
# to declare. Two halves, two owners: the SURFACE (verb `name` + arg `schema`) is
# machine-introspected and re-derived on anneal; your CURATION (`kind`/`group`/
# `danger`/`widget`/`label`) is preserved across re-derivation, joined by name.
# `kind` is one of read | setting | op. `danger` is a hint — star hints, Ouranos rules.
#
# [operable]
# schema = 1
#
# [[operable.verb]]
# name   = "example_ping"
# kind   = "read"
# group  = "health"
# danger = false
# widget = ""
# label  = "Ping"
